{% if section.settings.text != blank %}
  <div class="tc-announcement" role="region" aria-label="Store announcement">
    {% if section.settings.link != blank %}
      <a href="{{ section.settings.link }}">{{ section.settings.text }}</a>
    {% else %}
      <span>{{ section.settings.text }}</span>
    {% endif %}
  </div>
{% endif %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "default": "Free Metro Manila delivery for orders above ₱50,000 • COD available for selected items • Same-day pickup available"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Optional link"
    }
  ]
}
{% endschema %}
