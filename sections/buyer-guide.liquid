<section class="tc-section">
  <div class="tc-container">
    <div class="tc-section__header">
      <p class="tc-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="tc-section__title">{{ section.settings.title }}</h2>
    </div>

    <div class="tc-grid tc-grid--3">
      {% for block in section.blocks %}
        <article class="tc-guide-card" {{ block.shopify_attributes }}>
          <span class="tc-guide-card__icon" aria-hidden="true">{{ block.settings.icon }}</span>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
          {% if block.settings.link != blank %}
            <a class="tc-button tc-button--ghost tc-button--small" href="{{ block.settings.link }}">{{ block.settings.link_label }}</a>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Buyer guide",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Buying guide"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Find the Right Setup"
    }
  ],
  "blocks": [
    {
      "type": "guide",
      "name": "Guide card",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon text", "default": "01" },
        { "type": "text", "id": "title", "label": "Title", "default": "For Students" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Lightweight laptops, SSD storage, and accessories for classes and projects." },
        { "type": "url", "id": "link", "label": "Optional link" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Shop picks" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Buyer guide",
      "blocks": [
        { "type": "guide", "settings": { "icon": "ST", "title": "For Students", "text": "Reliable laptops, fast SSDs, webcams, and keyboards for school work." } },
        { "type": "guide", "settings": { "icon": "WF", "title": "For Work From Home", "text": "Business laptops, monitors, docking gear, routers, and backup storage." } },
        { "type": "guide", "settings": { "icon": "GM", "title": "For Gaming", "text": "Gaming laptops, GPUs, high-refresh monitors, and responsive peripherals." } },
        { "type": "guide", "settings": { "icon": "CR", "title": "For Creators", "text": "Color-ready displays, higher RAM, strong CPUs, and creator-grade GPUs." } },
        { "type": "guide", "settings": { "icon": "OT", "title": "For Office Teams", "text": "Bulk-friendly laptops, accessories, warranties, and deployment support." } },
        { "type": "guide", "settings": { "icon": "PC", "title": "For PC Builders", "text": "Compatible CPUs, boards, RAM, SSDs, cases, cooling, and power supplies." } }
      ]
    }
  ]
}
{% endschema %}
