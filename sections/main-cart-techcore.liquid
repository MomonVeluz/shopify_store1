<section class="tc-page-hero">
  <div class="tc-container">
    <p class="tc-eyebrow">Checkout ready</p>
    <h1 class="tc-page-title">Your Cart</h1>
  </div>
</section>

<section class="tc-container tc-page-body">
  {% if cart.item_count > 0 %}
    <form action="{{ routes.cart_url }}" method="post">
      <div class="tc-card" style="overflow:auto">
        <table class="tc-cart-table">
          <thead>
            <tr>
              <th>Product</th>
              <th>Qty</th>
              <th>Total</th>
            </tr>
          </thead>
          <tbody>
            {% for item in cart.items %}
              <tr>
                <td>
                  <div class="tc-cart-item">
                    {% if item.image %}
                      {{ item.image | image_url: width: 160 | image_tag: loading: 'lazy', alt: item.product.title }}
                    {% endif %}
                    <div>
                      <strong>{{ item.product.title }}</strong>
                      <p class="tc-muted" style="margin:.2rem 0 0">{{ item.variant.title }}</p>
                    </div>
                  </div>
                </td>
                <td>
                  <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" aria-label="Quantity for {{ item.product.title | escape }}">
                </td>
                <td>{{ item.final_line_price | money }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>

      <div class="tc-card" style="display:grid;gap:1rem;padding:1rem;margin-top:1rem">
        <div style="display:flex;justify-content:space-between;gap:1rem">
          <span class="tc-muted">Subtotal</span>
          <strong>{{ cart.total_price | money }}</strong>
        </div>
        <p class="tc-muted" style="margin:0">Shipping, COD eligibility, and payment options are calculated at checkout.</p>
        <div class="tc-action-row">
          <button class="tc-button tc-button--secondary" type="submit" name="update">Update cart</button>
          <button class="tc-button" type="submit" name="checkout">Checkout</button>
        </div>
      </div>
    </form>
  {% else %}
    <div class="tc-page-card">
      <h2>Your cart is empty</h2>
      <p>Start with laptops, PC parts, gaming accessories, or workstation upgrades.</p>
      <a class="tc-button" href="/collections/all">Shop products</a>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Cart"
}
{% endschema %}
