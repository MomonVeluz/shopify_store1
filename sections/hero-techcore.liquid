{% liquid
  assign hero_image = section.settings.image
  assign fallback_image = section.settings.fallback_image_url
%}

<section class="tc-hero">
  <div class="tc-container tc-hero__grid">
    <div class="tc-hero__copy">
      {% if section.settings.eyebrow != blank %}
        <p class="tc-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h1 class="tc-hero__title">{{ section.settings.heading }}</h1>
      <p class="tc-hero__text">{{ section.settings.subheading }}</p>
      <div class="tc-hero__actions">
        {% if section.settings.primary_label != blank %}
          <a class="tc-button" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>
        {% endif %}
        {% if section.settings.secondary_label != blank %}
          <a class="tc-button tc-button--secondary" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>
        {% endif %}
      </div>
    </div>

    <div class="tc-hero__media">
      {% if hero_image != blank %}
        {{ hero_image | image_url: width: 1400 | image_tag: loading: 'eager', sizes: '(min-width: 900px) 46vw, 100vw', alt: section.settings.image_alt }}
      {% else %}
        <img src="{{ fallback_image }}" alt="{{ section.settings.image_alt }}" width="1200" height="900" loading="eager">
      {% endif %}
      <div class="tc-hero__stat">
        <strong>{{ section.settings.stat_value }}</strong>
        <span>{{ section.settings.stat_label }}</span>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "TechCore hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Philippine-ready performance tech"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Headline",
      "default": "Power Your Work, Gaming, and Creativity"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheadline",
      "default": "Shop laptops, components, and accessories built for performance — with Philippine-ready payment and delivery options."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop Laptops"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Build Your PC"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "fallback_image_url",
      "label": "Fallback image URL",
      "default": "https://images.unsplash.com/photo-1593640408182-31c70c8268f5?auto=format&fit=crop&w=1400&q=80"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "Modern laptop and performance desk setup with blue lighting"
    },
    {
      "type": "text",
      "id": "stat_value",
      "label": "Stat value",
      "default": "Fast PH delivery"
    },
    {
      "type": "text",
      "id": "stat_label",
      "label": "Stat label",
      "default": "Metro Manila pickup and nationwide shipping"
    }
  ],
  "presets": [
    {
      "name": "TechCore hero"
    }
  ]
}
{% endschema %}
